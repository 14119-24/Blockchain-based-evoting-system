APP_ENV=production
APP_FORCE_HTTPS=true
# Optional if you want to override Render's detected public URL
APP_BASE_URL=https://your-service.onrender.com

DB_HOST=your-mysql-host
DB_PORT=3306
DB_NAME=voting_system
DB_USERNAME=your-db-user
DB_PASSWORD=your-db-password

# Optional dedicated admin database
ADMIN_DB_HOST=
ADMIN_DB_PORT=3306
ADMIN_DB_NAME=admin
ADMIN_DB_USERNAME=
ADMIN_DB_PASSWORD=

# Optional M-Pesa configuration
MPESA_ENVIRONMENT=sandbox
MPESA_SIMULATE=true
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_BUSINESS_SHORTCODE=
MPESA_PASSKEY=
MPESA_TRANSACTION_TYPE=CustomerPayBillOnline
MPESA_CALLBACK_URL=
MPESA_TIMEOUT=30
MPESA_CONNECTION_TIMEOUT=15
